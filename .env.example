# ============================================================================
# BUILDING DESIGN STUDIO - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in with your actual values
# DO NOT commit .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# NeonDB Connection String (PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Auth.js Secret - Generate with: openssl rand -hex 32
# Minimum 32 characters
AUTH_SECRET=replace-with-a-long-random-string

# GitHub OAuth (optional)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ============================================================================
# PUBLIC CONFIGURATION
# ============================================================================
# Public site URL - used for canonical URLs and social meta tags
NEXT_PUBLIC_SITE_URL=https://example.com

# Enable design mode for development (leave empty to disable)
# NEXT_PUBLIC_ENABLE_DESIGN_MODE=true

# ============================================================================
# APPWRITE/DEPLOYMENT
# ============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://example.com

# API Port (default: 3000 for production, 4000 for dev)
PORT=3000

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================
# Stripe (if implementing payments)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Email service
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ============================================================================
# LOGGING
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable detailed request logging
DEBUG=false
